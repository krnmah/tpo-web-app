generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id               Int      @id @default(autoincrement())
  name             String
  enrollmentNumber String   @unique
  email            String   @unique
  password         String
  department       String
  batch            Int
  tenthMarksheet   String   // URL/path to PDF
  twelfthMarksheet String   // URL/path to PDF
  resume           String   // URL/path to PDF
  profilePicture   String   // URL/path to JPG/JPEG/PNG
  isActivated      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}